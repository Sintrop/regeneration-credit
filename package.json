{
  "scripts": {
    "solhint": "./node_modules/.bin/solhint -f table contracts/**/**/*.sol",
    "prettier:solidity": "./node_modules/.bin/prettier --write contracts/**/**/*.sol",
    "prettier:js": "./node_modules/.bin/prettier --write test/**/**/*.js",
    "ganache:start": "ganache-cli -d -m 'sintrop' -a 10 -e 200 -i 5777 --chainId 5777 -h 0.0.0.0",
    "truffle:migrate": "truffle migrate",
    "truffle:migrate:reset": "truffle migrate --reset",
    "truffle:migrate:goerli": "truffle migrate --network goerli",
    "ipfs:start": "ipfs init || ipfs config Addresses.Gateway /ip4/0.0.0.0/tcp/8080 && ipfs config Addresses.API /ip4/0.0.0.0/tcp/5001 && ipfs daemon"
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run prettier:solidity"
    }
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.7.3",
    "@truffle/hdwallet-provider": "^1.0.41-1",
    "dotenv": "^16.0.2",
    "solc": "^0.8.17"
  },
  "devDependencies": {
    "@openzeppelin/test-helpers": "^0.5.16",
    "husky": "^8.0.1",
    "prettier": "2.8.2",
    "prettier-plugin-solidity": "^1.0.0-beta.24",
    "solhint": "^3.3.7",
    "solhint-plugin-prettier": "^0.0.5",
    "web3": "^1.8.0"
  }
}
